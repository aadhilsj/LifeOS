{
  "routes": [
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/icon-192.png", "dest": "/icon-192.png" },
    { "src": "/icon-512.png", "dest": "/icon-512.png" },
    { "src": "/sw.js", "dest": "/sw.js" },

    { "src": "/api/review", "dest": "/api/review.js" },
    { "src": "/api/voice", "dest": "/api/voice.js" },
    { "src": "/api/calendar/auth", "dest": "/api/calendar/auth.js" },
    { "src": "/api/calendar/callback", "dest": "/api/calendar/callback.js" },
    { "src": "/api/calendar", "dest": "/api/calendar.js" },

    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
